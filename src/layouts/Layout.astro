---
import '../styles/global.css';
import Logo from '../components/ui/Logo.astro';
import { pwaInfo } from 'virtual:pwa-info';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro'

export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  image?: string;
}

const {
  title,
  description = 'Estudia y aprueba el examen teórico de conducción en Cuba. Basado en la Ley 109 del Código de Seguridad Vial.',
  activeNav = '',
  image = '/icons/icon-512.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://viasegura.vercel.app');
const optimizedTitle = `${title} | VíaSegura`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <title>{optimizedTitle}</title>
    
    <!-- SEO & Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={optimizedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={optimizedTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, canonicalURL)} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "VíaSegura",
      "url": canonicalURL.toString(),
      "description": description,
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />

    <ClientRouter />
    <Analytics />

    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <!-- Prevent FOUC: apply theme before render -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('viasegura_theme');
        let theme = 'light';
        if (stored) {
          try { theme = JSON.parse(stored).data; } catch(e) {}
        }
        if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-surface-50 text-surface-900 dark:bg-surface-950 dark:text-surface-100 transition-colors duration-300 pb-20 md:pb-0">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/85 dark:bg-surface-950/85 backdrop-blur-xl border-b border-surface-200 dark:border-surface-800 shadow-xs safe-top">
      <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
          <a href="/" class="flex items-center gap-2.5 group" id="header-logo">
            <Logo size="md" class="text-white drop-shadow-sm group-hover:scale-105 transition-transform duration-300" />
            <span class="font-bold text-xl tracking-tight text-surface-900 dark:text-white group-hover:opacity-80 transition-opacity">
              Vía<span class="text-primary-600 dark:text-primary-400">Segura</span>
            </span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-1.5" id="desktop-nav">
            <a href="/" class:list={[
              "flex items-center gap-1.5 px-3 py-1.5 rounded-xl font-medium text-sm transition-all",
              activeNav === 'home' 
                ? "bg-primary-500 text-white shadow-md shadow-primary-500/20" 
                : "text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 hover:text-primary-600 dark:hover:text-primary-400"
            ]}>
              <span class="opacity-70 text-base">🏠</span> Inicio
            </a>
            <a href="/estudiar" class:list={[
              "flex items-center gap-1.5 px-3 py-1.5 rounded-xl font-medium text-sm transition-all",
              activeNav === 'estudiar' 
                ? "bg-primary-500 text-white shadow-md shadow-primary-500/20" 
                : "text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 hover:text-primary-600 dark:hover:text-primary-400"
            ]}>
              <span class="opacity-70 text-base">📚</span> Estudiar
            </a>
            <a href="/senales" class:list={[
              "flex items-center gap-1.5 px-3 py-1.5 rounded-xl font-medium text-sm transition-all",
              activeNav === 'senales' 
                ? "bg-primary-500 text-white shadow-md shadow-primary-500/20" 
                : "text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 hover:text-primary-600 dark:hover:text-primary-400"
            ]}>
              <span class="opacity-70 text-base">🚦</span> Señales
            </a>
            <a href="/practica" class:list={[
              "flex items-center gap-1.5 px-3 py-1.5 rounded-xl font-medium text-sm transition-all",
              activeNav === 'practica' 
                ? "bg-primary-500 text-white shadow-md shadow-primary-500/20" 
                : "text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 hover:text-primary-600 dark:hover:text-primary-400"
            ]}>
              <span class="opacity-70 text-base">✍️</span> Práctica
            </a>
            <a href="/examen" class:list={[
              "flex items-center gap-1.5 px-3 py-1.5 rounded-xl font-medium text-sm transition-all",
              activeNav === 'examen' 
                ? "bg-primary-500 text-white shadow-md shadow-primary-500/20" 
                : "text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 hover:text-primary-600 dark:hover:text-primary-400"
            ]}>
              <span class="opacity-70 text-base">📝</span> Examen
            </a>
            <a href="/progreso" class:list={[
              "flex items-center gap-1.5 px-3 py-1.5 rounded-xl font-medium text-sm transition-all",
              activeNav === 'progreso' 
                ? "bg-primary-500 text-white shadow-md shadow-primary-500/20" 
                : "text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-800 hover:text-primary-600 dark:hover:text-primary-400"
            ]}>
              <span class="opacity-70 text-base">📊</span> Progreso
            </a>
          </nav>

          <!-- Theme Toggle -->
          <button id="theme-toggle" class="p-2 ml-2 rounded-xl text-surface-500 hover:text-surface-900 hover:bg-surface-100 dark:text-surface-400 dark:hover:text-surface-100 dark:hover:bg-surface-800 transition-colors" aria-label="Cambiar tema">
            <svg id="theme-icon-light" class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-icon-dark" class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 py-6 animate-fade-in">
      <slot />
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white/90 dark:bg-surface-950/90 backdrop-blur-xl border-t border-surface-200 dark:border-surface-800 shadow-[0_-4px_24px_rgba(0,0,0,0.05)] dark:shadow-[0_-4px_24px_rgba(0,0,0,0.4)] safe-bottom" id="mobile-nav">
      <div class="flex items-center justify-around h-16 px-2">
        <a href="/" class:list={[
            "flex flex-col items-center justify-center p-2 min-w-[3.5rem] transition-colors",
            activeNav === 'home' ? "text-primary-600 dark:text-primary-400" : "text-surface-500 dark:text-surface-400"
          ]}>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
            <span class="text-[10px] mt-0.5 font-medium">Inicio</span>
          </a>
          <a href="/estudiar" class:list={[
            "flex flex-col items-center justify-center p-2 min-w-[3.5rem] transition-colors",
            activeNav === 'estudiar' ? "text-primary-600 dark:text-primary-400" : "text-surface-500 dark:text-surface-400"
          ]}>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
            <span class="text-[10px] mt-0.5 font-medium">Estudiar</span>
          </a>
          <a href="/practica" class:list={[
            "flex flex-col items-center justify-center p-2 min-w-[3.5rem] transition-colors",
            activeNav === 'practica' ? "text-primary-600 dark:text-primary-400" : "text-surface-500 dark:text-surface-400"
          ]}>
            <div class="relative -mt-5 bg-linear-to-br from-primary-500 to-primary-600 rounded-2xl p-3 shadow-[0_8px_16px_rgba(59,130,246,0.3)] dark:shadow-[0_8px_16px_rgba(59,130,246,0.2)]">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
            </div>
            <span class="text-[10px] mt-1 font-medium">Práctica</span>
          </a>
          <a href="/examen" class:list={[
            "flex flex-col items-center justify-center p-2 min-w-[3.5rem] transition-colors",
            activeNav === 'examen' ? "text-primary-600 dark:text-primary-400" : "text-surface-500 dark:text-surface-400"
          ]}>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>
            <span class="text-[10px] mt-0.5 font-medium">Examen</span>
          </a>
          <a href="/progreso" class:list={[
            "flex flex-col items-center justify-center p-2 min-w-[3.5rem] transition-colors",
            activeNav === 'progreso' ? "text-primary-600 dark:text-primary-400" : "text-surface-500 dark:text-surface-400"
          ]}>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
            <span class="text-[10px] mt-0.5 font-medium">Progreso</span>
          </a>
        </div>
      </div>
    </nav>

    <!-- PWA script -->
    <script>
      import { registerSW } from 'virtual:pwa-register';

      registerSW({
        immediate: true,
        onRegisteredSW(swScriptUrl: string) {
          console.log('[VíaSegura] SW registered:', swScriptUrl);
        },
        onOfflineReady() {
          console.log('[VíaSegura] App ready to work offline');
        },
      });
    </script>

    <!-- Theme toggle + init stores -->
    <script>
      import { initStores, setTheme, applyTheme, $theme } from '../lib/store';

      // Initialize stores and bind events on every page transition
      document.addEventListener('astro:after-swap', () => {
        applyTheme($theme.get());
      });

      document.addEventListener('astro:page-load', () => {
        initStores();

        // Theme toggle button
        const themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
          themeBtn.addEventListener('click', () => {
            const current = document.documentElement.classList.contains('dark');
            setTheme(current ? 'light' : 'dark');
          });
        }
      });

      // Listen for system theme changes (binds once globally)
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        const currentTheme = $theme.get();
        if (currentTheme === 'system') {
          document.documentElement.classList.toggle('dark', e.matches);
        }
      });
    </script>

    <style>
      .nav-link {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-surface-600);
        transition: all 0.2s ease;
      }
      .dark .nav-link {
        color: var(--color-surface-400);
      }
      .nav-link:hover {
        background-color: var(--color-surface-100);
        color: var(--color-primary-600);
      }
      .dark .nav-link:hover {
        background-color: var(--color-surface-800);
        color: var(--color-primary-400);
      }
      .nav-link.active {
        background-color: var(--color-primary-500);
        color: white;
      }
      .dark .nav-link.active {
        background-color: var(--color-primary-600);
      }

      .mobile-nav-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0.25rem;
        min-width: 3.5rem;
        color: var(--color-surface-500);
        transition: color 0.2s ease;
      }
      .mobile-nav-link.active {
        color: var(--color-primary-500);
      }
      .dark .mobile-nav-link.active {
        color: var(--color-primary-400);
      }
    </style>
  </body>
</html>

---
import '../styles/global.css';
import { pwaInfo } from 'virtual:pwa-info';
export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const {
  title,
  description = 'Estudia y aprueba el examen teórico de conducción en Cuba. Basado en la Ley 109 del Código de Seguridad Vial.',
  activeNav = '',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <title>{title} | VíaSegura</title>

    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <!-- Prevent FOUC: apply theme before render -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('viasegura_theme');
        let theme = 'system';
        if (stored) {
          try { theme = JSON.parse(stored).data; } catch(e) {}
        }
        if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-surface-50 text-surface-900 dark:bg-surface-950 dark:text-surface-100 transition-colors duration-300 pb-20 md:pb-0">
    <!-- Header -->
    <header class="sticky top-0 z-50 safe-top">
      <div class="glass border-b border-surface-200 dark:border-surface-800">
        <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
          <a href="/" class="flex items-center gap-2 group" id="header-logo">
            <span class="text-2xl">🛡️</span>
            <span class="font-bold text-lg bg-gradient-to-r from-primary-500 to-primary-400 bg-clip-text text-transparent group-hover:from-primary-400 group-hover:to-accent-500 transition-all duration-300">VíaSegura</span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-1" id="desktop-nav">
            <a href="/" class:list={["nav-link", { active: activeNav === 'home' }]}>
              <span>🏠</span> Inicio
            </a>
            <a href="/estudiar" class:list={["nav-link", { active: activeNav === 'estudiar' }]}>
              <span>📚</span> Estudiar
            </a>
            <a href="/senales" class:list={["nav-link", { active: activeNav === 'senales' }]}>
              <span>🚦</span> Señales
            </a>
            <a href="/practica" class:list={["nav-link", { active: activeNav === 'practica' }]}>
              <span>✍️</span> Práctica
            </a>
            <a href="/examen" class:list={["nav-link", { active: activeNav === 'examen' }]}>
              <span>📝</span> Examen
            </a>
            <a href="/progreso" class:list={["nav-link", { active: activeNav === 'progreso' }]}>
              <span>📊</span> Progreso
            </a>
          </nav>

          <!-- Theme Toggle -->
          <button id="theme-toggle" class="p-2 rounded-xl hover:bg-surface-200 dark:hover:bg-surface-800 transition-colors" aria-label="Cambiar tema">
            <svg id="theme-icon-light" class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-icon-dark" class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 py-6 animate-fade-in">
      <slot />
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 safe-bottom" id="mobile-nav">
      <div class="glass border-t border-surface-200 dark:border-surface-800">
        <div class="flex items-center justify-around h-16 px-2">
          <a href="/" class:list={["mobile-nav-link", { active: activeNav === 'home' }]} id="nav-home">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
            <span class="text-[10px] mt-0.5">Inicio</span>
          </a>
          <a href="/estudiar" class:list={["mobile-nav-link", { active: activeNav === 'estudiar' }]} id="nav-estudiar">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
            <span class="text-[10px] mt-0.5">Estudiar</span>
          </a>
          <a href="/practica" class:list={["mobile-nav-link", { active: activeNav === 'practica' }]} id="nav-practica">
            <div class="relative -mt-4 bg-gradient-to-br from-primary-500 to-primary-600 rounded-2xl p-3 shadow-lg shadow-primary-500/30">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
            </div>
            <span class="text-[10px] mt-1">Práctica</span>
          </a>
          <a href="/examen" class:list={["mobile-nav-link", { active: activeNav === 'examen' }]} id="nav-examen">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>
            <span class="text-[10px] mt-0.5">Examen</span>
          </a>
          <a href="/progreso" class:list={["mobile-nav-link", { active: activeNav === 'progreso' }]} id="nav-progreso">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
            <span class="text-[10px] mt-0.5">Progreso</span>
          </a>
        </div>
      </div>
    </nav>

    <!-- PWA script -->
    <script>
      import { registerSW } from 'virtual:pwa-register';

      registerSW({
        immediate: true,
        onRegisteredSW(swScriptUrl: string) {
          console.log('[VíaSegura] SW registered:', swScriptUrl);
        },
        onOfflineReady() {
          console.log('[VíaSegura] App ready to work offline');
        },
      });
    </script>

    <!-- Theme toggle + init stores -->
    <script>
      import { initStores, setTheme, $theme } from '../lib/store';

      // Initialize stores on load
      document.addEventListener('DOMContentLoaded', () => {
        initStores();
      });

      // Theme toggle button
      const themeBtn = document.getElementById('theme-toggle');
      if (themeBtn) {
        themeBtn.addEventListener('click', () => {
          const current = document.documentElement.classList.contains('dark');
          setTheme(current ? 'light' : 'dark');
        });
      }

      // Listen for system theme changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        const currentTheme = $theme.get();
        if (currentTheme === 'system') {
          document.documentElement.classList.toggle('dark', e.matches);
        }
      });
    </script>

    <style>
      .nav-link {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-surface-600);
        transition: all 0.2s ease;
      }
      .dark .nav-link {
        color: var(--color-surface-400);
      }
      .nav-link:hover {
        background-color: var(--color-surface-100);
        color: var(--color-primary-600);
      }
      .dark .nav-link:hover {
        background-color: var(--color-surface-800);
        color: var(--color-primary-400);
      }
      .nav-link.active {
        background-color: var(--color-primary-500);
        color: white;
      }
      .dark .nav-link.active {
        background-color: var(--color-primary-600);
      }

      .mobile-nav-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0.25rem;
        min-width: 3.5rem;
        color: var(--color-surface-500);
        transition: color 0.2s ease;
      }
      .mobile-nav-link.active {
        color: var(--color-primary-500);
      }
      .dark .mobile-nav-link.active {
        color: var(--color-primary-400);
      }
    </style>
  </body>
</html>

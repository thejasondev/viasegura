---
import Layout from '../../layouts/Layout.astro';
import SignalIcon from '../../components/SignalIcon.astro';
import { signals } from '../../data/signals';
---

<Layout title="Quiz de Señales" activeNav="senales">
  <!-- Setup Screen -->
  <div id="signal-quiz-setup">
    <div class="text-center mb-8">
      <div class="text-6xl mb-4">🚦</div>
      <h1 class="text-2xl md:text-3xl font-bold mb-2">Quiz Visual de Señales</h1>
      <p class="text-surface-500 dark:text-surface-400 max-w-md mx-auto">
        Pon a prueba tu capacidad de reconocer señales de tránsito. ¡Identifica cada señal correctamente!
      </p>
    </div>

    <div class="max-w-lg mx-auto">
      <div class="bg-surface-100 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 mb-6">
        <h2 class="font-bold mb-4">Selecciona el modo</h2>
        <div class="space-y-3" id="mode-select">
          <button class="mode-btn active w-full text-left p-4 rounded-xl border-2 border-primary-500 bg-primary-500/10 transition-all" data-mode="identify">
            <div class="font-bold text-sm mb-0.5">🔍 Identificar señal</div>
            <div class="text-xs text-surface-500">Ves la señal → eliges su significado</div>
          </button>
          <button class="mode-btn w-full text-left p-4 rounded-xl border-2 border-surface-200 dark:border-surface-800 hover:border-primary-500/50 transition-all" data-mode="find">
            <div class="font-bold text-sm mb-0.5">🎯 Encontrar señal</div>
            <div class="text-xs text-surface-500">Lees el significado → eliges la señal correcta</div>
          </button>
        </div>
      </div>

      <div class="bg-surface-100 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 mb-6">
        <h2 class="font-bold mb-4">Cantidad</h2>
        <div class="flex gap-3" id="sq-count-select">
          <button class="sq-count-btn px-6 py-3 rounded-xl border border-surface-200 dark:border-surface-800 font-bold hover:border-primary-500/50 transition-all" data-count="5">5</button>
          <button class="sq-count-btn active px-6 py-3 rounded-xl border border-primary-500 bg-primary-500/10 font-bold transition-all" data-count="10">10</button>
          <button class="sq-count-btn px-6 py-3 rounded-xl border border-surface-200 dark:border-surface-800 font-bold hover:border-primary-500/50 transition-all" data-count="15">15</button>
        </div>
      </div>

      <button id="start-signal-quiz" class="w-full py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-primary-500 to-primary-600 text-white hover:from-primary-600 hover:to-primary-700 active:scale-[0.98] transition-all shadow-lg shadow-primary-500/20">
        🚀 Comenzar Quiz de Señales
      </button>

      <div class="text-center mt-4">
        <a href="/senales" class="text-sm text-surface-400 hover:text-primary-500 underline">← Volver al glosario de señales</a>
      </div>
    </div>
  </div>

  <!-- Quiz Screen -->
  <div id="signal-quiz-screen" class="hidden">
    <div class="flex items-center gap-4 mb-6">
      <div class="flex-1 h-2 bg-surface-200 dark:bg-surface-800 rounded-full overflow-hidden">
        <div class="h-full bg-gradient-to-r from-primary-500 to-success-500 rounded-full transition-all duration-500" id="sq-progress-bar" style="width: 0%"></div>
      </div>
      <span class="text-sm font-bold" id="sq-counter">1/10</span>
    </div>

    <!-- Signal display area -->
    <div class="bg-surface-100 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 md:p-8 mb-6">
      <div class="flex justify-center mb-6" id="sq-signal-display">
        <!-- Signal SVG or text will be injected here -->
      </div>
      <h2 class="text-lg md:text-xl font-bold text-center mb-6" id="sq-question-text"></h2>
      <div class="space-y-3" id="sq-options"></div>
    </div>

    <!-- Feedback -->
    <div class="hidden rounded-2xl p-6 mb-6" id="sq-feedback">
      <div class="flex items-start gap-3">
        <span class="text-2xl" id="sq-feedback-icon"></span>
        <div>
          <div class="font-bold mb-1" id="sq-feedback-title"></div>
          <p class="text-sm" id="sq-feedback-text"></p>
        </div>
      </div>
    </div>

    <button id="sq-next-btn" class="hidden w-full py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-primary-500 to-primary-600 text-white hover:from-primary-600 hover:to-primary-700 active:scale-[0.98] transition-all">
      Siguiente →
    </button>
  </div>

  <!-- Results -->
  <div id="signal-quiz-results" class="hidden animate-scale-in">
    <div class="text-center mb-8">
      <div class="text-6xl mb-4" id="sq-result-emoji">🎉</div>
      <h2 class="text-3xl font-black mb-2" id="sq-result-title">¡Bien hecho!</h2>
      <p class="text-surface-500 dark:text-surface-400" id="sq-result-subtitle"></p>
    </div>

    <div class="bg-surface-100 dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 mb-6">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div>
          <div class="text-3xl font-black text-primary-500" id="sq-r-score">0%</div>
          <div class="text-xs text-surface-500">Puntuación</div>
        </div>
        <div>
          <div class="text-3xl font-black text-success-500" id="sq-r-correct">0</div>
          <div class="text-xs text-surface-500">Correctas</div>
        </div>
        <div>
          <div class="text-3xl font-black text-danger-500" id="sq-r-wrong">0</div>
          <div class="text-xs text-surface-500">Incorrectas</div>
        </div>
      </div>
    </div>

    <div class="flex gap-3">
      <a href="/senales/quiz" class="flex-1 py-3 rounded-xl font-semibold bg-primary-500 text-white text-center hover:bg-primary-600 transition-all">🔄 Repetir</a>
      <a href="/senales" class="flex-1 py-3 rounded-xl font-semibold bg-surface-200 dark:bg-surface-800 text-center hover:bg-surface-300 dark:hover:bg-surface-700 transition-all">🚦 Glosario</a>
    </div>
  </div>

  <!-- Hidden signal data for JS -->
  <script define:vars={{ signalData: JSON.stringify(signals.map(s => ({ id: s.id, name: s.name, category: s.category, description: s.description, meaning: s.meaning, svgIcon: s.svgIcon }))) }}>
    window.__SIGNAL_DATA__ = JSON.parse(signalData);
  </script>

  <!-- Render all signal SVGs as hidden templates for JS access -->
  <div id="signal-svg-templates" class="hidden" aria-hidden="true">
    {signals.map((signal) => (
      <div data-signal-id={signal.id}>
        <SignalIcon name={signal.svgIcon} size="lg" />
      </div>
    ))}
  </div>
</Layout>

<script>
  import { recordStudyActivity } from '../../lib/store';

  let mode = 'identify';
  let count = 10;
  let quizSignals = [];
  let currentIndex = 0;
  let correctCount = 0;
  let answered = false;

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function getSignalSvgHtml(signalId) {
    const template = document.querySelector(`#signal-svg-templates [data-signal-id="${signalId}"]`);
    return template ? template.innerHTML : `<span class="text-6xl">❓</span>`;
  }

  function initSignalQuiz() {
    if (!document.getElementById('signal-quiz-setup')) return;

    // Mode selection
    document.querySelectorAll('.mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach(b => {
          b.classList.remove('border-primary-500', 'bg-primary-500/10');
          b.classList.add('border-surface-200', 'dark:border-surface-800');
        });
        btn.classList.add('border-primary-500', 'bg-primary-500/10');
        btn.classList.remove('border-surface-200', 'dark:border-surface-800');
        mode = btn.getAttribute('data-mode') || 'identify';
      });
    });

    // Count selection
    document.querySelectorAll('.sq-count-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sq-count-btn').forEach(b => {
          b.classList.remove('border-primary-500', 'bg-primary-500/10');
          b.classList.add('border-surface-200', 'dark:border-surface-800');
        });
        btn.classList.add('border-primary-500', 'bg-primary-500/10');
        btn.classList.remove('border-surface-200', 'dark:border-surface-800');
        count = parseInt(btn.getAttribute('data-count') || '10');
      });
    });

    // Start
    document.getElementById('start-signal-quiz')?.addEventListener('click', () => {
      const allSignals = window.__SIGNAL_DATA__ || [];
      quizSignals = shuffle(allSignals).slice(0, count);
      currentIndex = 0;
      correctCount = 0;
      answered = false;
      recordStudyActivity();

      document.getElementById('signal-quiz-setup').classList.add('hidden');
      document.getElementById('signal-quiz-screen').classList.remove('hidden');
      showSignalQuestion();
    });

    document.getElementById('sq-next-btn')?.addEventListener('click', () => {
      currentIndex++;
      if (currentIndex >= quizSignals.length) {
        showSignalResults();
      } else {
        showSignalQuestion();
      }
    });
  }

  function showSignalQuestion() {
    answered = false;
    const signal = quizSignals[currentIndex];
    const allSignals = window.__SIGNAL_DATA__ || [];

    // Generate 3 wrong options
    const wrongOptions = shuffle(allSignals.filter(s => s.id !== signal.id)).slice(0, 3);

    document.getElementById('sq-counter').textContent = `${currentIndex + 1}/${quizSignals.length}`;
    document.getElementById('sq-progress-bar').style.width = `${(currentIndex / quizSignals.length) * 100}%`;

    const displayEl = document.getElementById('sq-signal-display');
    const questionEl = document.getElementById('sq-question-text');
    const optionsEl = document.getElementById('sq-options');

    if (mode === 'identify') {
      // Show signal image, choose meaning
      displayEl.innerHTML = `<div class="w-28 h-28">${getSignalSvgHtml(signal.id)}</div>`;
      questionEl.textContent = '¿Qué significa esta señal?';

      const options = shuffle([
        { text: signal.meaning, correct: true },
        ...wrongOptions.map(w => ({ text: w.meaning, correct: false }))
      ]);

      optionsEl.innerHTML = '';
      options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = 'sq-option w-full text-left p-4 rounded-xl border-2 border-surface-200 dark:border-surface-800 hover:border-primary-500/50 transition-all font-medium text-sm';
        btn.innerHTML = `<span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-surface-200 dark:bg-surface-800 text-xs font-bold mr-3">${String.fromCharCode(65 + i)}</span>${opt.text}`;
        btn.addEventListener('click', () => handleSignalAnswer(opt.correct, signal));
        optionsEl.appendChild(btn);
      });
    } else {
      // Show meaning text, choose signal image
      displayEl.innerHTML = '';
      questionEl.textContent = `¿Cuál es la señal de "${signal.name}"?`;

      const options = shuffle([
        { id: signal.id, name: signal.name, correct: true },
        ...wrongOptions.map(w => ({ id: w.id, name: w.name, correct: false }))
      ]);

      optionsEl.innerHTML = '';
      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-2 gap-3';
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'sq-option p-4 rounded-xl border-2 border-surface-200 dark:border-surface-800 hover:border-primary-500/50 transition-all flex flex-col items-center gap-2';
        btn.innerHTML = `<div class="w-16 h-16">${getSignalSvgHtml(opt.id)}</div><span class="text-xs font-medium text-center">${opt.name}</span>`;
        btn.addEventListener('click', () => handleSignalAnswer(opt.correct, signal));
        grid.appendChild(btn);
      });
      optionsEl.appendChild(grid);
    }

    document.getElementById('sq-feedback').classList.add('hidden');
    document.getElementById('sq-next-btn').classList.add('hidden');
  }

  function handleSignalAnswer(isCorrect, signal) {
    if (answered) return;
    answered = true;

    if (isCorrect) correctCount++;

    // Highlight
    document.querySelectorAll('.sq-option').forEach(opt => {
      opt.classList.add('pointer-events-none');
    });

    const feedbackEl = document.getElementById('sq-feedback');
    feedbackEl.classList.remove('hidden');
    feedbackEl.className = `rounded-2xl p-6 mb-6 ${isCorrect ? 'bg-success-500/10 border border-success-500/20' : 'bg-danger-500/10 border border-danger-500/20'}`;
    document.getElementById('sq-feedback-icon').textContent = isCorrect ? '✅' : '❌';
    document.getElementById('sq-feedback-title').textContent = isCorrect ? '¡Correcto!' : 'Incorrecto';
    document.getElementById('sq-feedback-text').textContent = `${signal.name}: ${signal.meaning}`;
    document.getElementById('sq-next-btn').classList.remove('hidden');
    document.getElementById('sq-progress-bar').style.width = `${((currentIndex + 1) / quizSignals.length) * 100}%`;
  }

  function showSignalResults() {
    document.getElementById('signal-quiz-screen').classList.add('hidden');
    document.getElementById('signal-quiz-results').classList.remove('hidden');

    const score = Math.round((correctCount / quizSignals.length) * 100);
    const emoji = score >= 90 ? '🌟' : score >= 70 ? '🎉' : score >= 50 ? '📚' : '💪';
    const title = score >= 90 ? '¡Experto en Señales!' : score >= 70 ? '¡Bien hecho!' : score >= 50 ? 'Vas mejorando' : 'Sigue estudiando';

    document.getElementById('sq-result-emoji').textContent = emoji;
    document.getElementById('sq-result-title').textContent = title;
    document.getElementById('sq-result-subtitle').textContent = `Identificaste correctamente ${correctCount} de ${quizSignals.length} señales.`;
    document.getElementById('sq-r-score').textContent = `${score}%`;
    document.getElementById('sq-r-correct').textContent = String(correctCount);
    document.getElementById('sq-r-wrong').textContent = String(quizSignals.length - correctCount);
  }

  document.addEventListener('astro:page-load', initSignalQuiz);
</script>

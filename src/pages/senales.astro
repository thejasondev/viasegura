---
import Layout from '../layouts/Layout.astro';
import SignalCard from '../components/signals/SignalCard.astro';
import { signals, signalCategories } from '../data/signals';
---

<Layout title="Señales de Tránsito" activeNav="senales">
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold mb-2">🚦 Señales de Tránsito</h1>
    <p class="text-surface-500 dark:text-surface-400">Aprende todas las señales. Toca una tarjeta para ver su significado.</p>
  </div>

  <!-- Category Tabs -->
  <div class="flex gap-2 overflow-x-auto pb-3 mb-6 scrollbar-hide" id="signal-tabs">
    {signalCategories.map((cat, i) => (
      <button
        class:list={[
          "signal-tab flex-shrink-0 flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium border transition-all whitespace-nowrap",
          i === 0 ? "border-primary-500 bg-primary-500/10 text-primary-500" : "border-surface-200 dark:border-surface-800 hover:border-primary-500/50"
        ]}
        data-category={cat.id}
      >
        <span>{cat.icon}</span>
        <span>{cat.label}</span>
        <span class="text-[10px] font-bold bg-surface-200 dark:bg-surface-700 px-1.5 py-0.5 rounded-md">{cat.count}</span>
      </button>
    ))}
  </div>

  <!-- Signals Grid -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3" id="signals-grid">
    {signals.map((signal) => (
      <SignalCard signal={signal} />
    ))}
  </div>
</Layout>

<script>
  // Initialize logic on page load (supports View Transitions)
  document.addEventListener('astro:page-load', () => {
    // Category filtering
    document.querySelectorAll('.signal-tab').forEach((tab) => {
      // Remove old listeners to prevent duplicates (safeguard)
      const newTab = tab.cloneNode(true) as HTMLElement;
      tab.parentNode?.replaceChild(newTab, tab);

      newTab.addEventListener('click', () => {
        document.querySelectorAll('.signal-tab').forEach((t) => {
          t.classList.remove('border-primary-500', 'bg-primary-500/10', 'text-primary-500');
          t.classList.add('border-surface-200', 'dark:border-surface-800');
        });
        newTab.classList.add('border-primary-500', 'bg-primary-500/10', 'text-primary-500');
        newTab.classList.remove('border-surface-200', 'dark:border-surface-800');

        const category = newTab.getAttribute('data-category');
        document.querySelectorAll('.signal-card').forEach((card) => {
          const cardCat = card.getAttribute('data-category');
          if (category === 'all' || cardCat === category) {
            (card as HTMLElement).style.display = '';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });

    // Card flip
    document.querySelectorAll('.signal-card').forEach((card) => {
      const newCard = card.cloneNode(true) as HTMLElement;
      card.parentNode?.replaceChild(newCard, card);

      newCard.addEventListener('click', () => {
        const inner = newCard.querySelector('.preserve-3d') as HTMLElement;
        const isFlipped = inner.getAttribute('data-flipped') === 'true';
        if (isFlipped) {
          inner.style.transform = 'rotateY(0deg)';
          inner.setAttribute('data-flipped', 'false');
        } else {
          inner.style.transform = 'rotateY(180deg)';
          inner.setAttribute('data-flipped', 'true');
        }
      });
    });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

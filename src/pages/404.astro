---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <div class="text-center py-20">
    <div class="text-7xl mb-6">🚧</div>
    <h1 class="text-3xl font-bold mb-3">Página no encontrada</h1>
    <p class="text-surface-500 dark:text-surface-400 mb-8">
      Parece que esta ruta no existe. ¡Como una calle sin salida!
    </p>
    <a href="/" class="inline-flex items-center gap-2 bg-primary-500 text-white font-bold px-6 py-3 rounded-2xl hover:bg-primary-600 transition-all shadow-lg">
      🏠 Volver al Inicio
    </a>
  </div>
</Layout>

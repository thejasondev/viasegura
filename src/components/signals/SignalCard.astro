---
import type { TrafficSignal } from '../../lib/types';
import Badge from '../ui/Badge.astro';

export interface Props {
  signal: TrafficSignal;
}

const { signal } = Astro.props;

const categoryVariant = signal.category === 'prohibitiva' ? 'danger' 
  : signal.category === 'obligatoria' ? 'primary'
  : signal.category === 'preventiva' ? 'warning'
  : signal.category === 'informativa' ? 'success'
  : 'warning'; // transitoria
---

<div class="signal-card group perspective-1000 cursor-pointer" data-category={signal.category}>
  <div class="relative preserve-3d transition-transform duration-500 h-48" data-flipped="false">
    <!-- Front -->
    <div class="absolute inset-0 backface-hidden rounded-2xl bg-surface-100 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 p-4 flex flex-col items-center justify-center text-center group-hover:border-primary-500/30 transition-colors">
      <div class="text-4xl mb-3">{signal.svgIcon}</div>
      <h3 class="font-bold text-sm mb-1">{signal.name}</h3>
      <Badge text={signal.category} variant={categoryVariant} uppercase={true} />
      <p class="text-[11px] text-surface-400 mt-2">Toca para ver más</p>
    </div>
    <!-- Back -->
    <div class="absolute inset-0 backface-hidden rotate-y-180 rounded-2xl bg-gradient-to-br from-primary-600 to-primary-700 text-white p-4 flex flex-col items-center justify-center text-center">
      <div class="text-2xl mb-2">{signal.svgIcon}</div>
      <h3 class="font-bold text-sm mb-2">{signal.name}</h3>
      <p class="text-xs text-white/80 leading-relaxed">{signal.meaning}</p>
    </div>
  </div>
</div>

---
interface Props {
  name: string;
  className?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
}

const { name, className = '', size = 'md' } = Astro.props;

const sizeMap = {
  sm: 'w-6 h-6',
  md: 'w-10 h-10',
  lg: 'w-16 h-16',
  xl: 'w-24 h-24',
};

const dimensions = sizeMap[size];

// Helper to determine which SVG drawing to load
const getSignalSVG = (signName: string) => {
  switch (signName) {
    case 'pare':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <polygon points="30,5 70,5 95,30 95,70 70,95 30,95 5,70 5,30" fill="#dc2626" stroke="#ffffff" stroke-width="3"/>
          <polygon points="32,8 68,8 92,32 92,68 68,92 32,92 8,68 8,32" fill="#dc2626" stroke="#ffffff" stroke-width="1"/>
          <text x="50" y="58" font-family="Arial, sans-serif" font-weight="bold" font-size="28" fill="white" text-anchor="middle">PARE</text>
        </svg>
      `;
    case 'ceda':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <polygon points="5,5 95,5 50,85" fill="#ffffff" stroke="#dc2626" stroke-width="12" stroke-linejoin="round"/>
        </svg>
      `;
    case 'velocidad_50':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <text x="50" y="65" font-family="Arial, sans-serif" font-weight="900" font-size="45" fill="black" text-anchor="middle">50</text>
        </svg>
      `;
    case 'velocidad_30':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <text x="50" y="65" font-family="Arial, sans-serif" font-weight="900" font-size="45" fill="black" text-anchor="middle">30</text>
        </svg>
      `;
    case 'no_girar_izquierda':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <!-- Arrow pointing left -->
          <path d="M 70 50 L 40 50 M 40 50 L 55 35 M 40 50 L 55 65" stroke="#000000" stroke-width="10" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <!-- Diagonal prohibition line -->
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'no_girar_derecha':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <!-- Arrow pointing right -->
          <path d="M 30 50 L 60 50 M 60 50 L 45 35 M 60 50 L 45 65" stroke="#000000" stroke-width="10" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <!-- Diagonal prohibition line -->
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'no_entrar': // Dirección prohibida
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="46" fill="#dc2626" />
          <rect x="20" y="42" width="60" height="16" fill="#ffffff" rx="2" />
        </svg>
      `;
    case 'no_sonar_bocina':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <!-- Horn shape -->
          <path d="M 30 45 L 45 45 L 60 30 L 60 70 L 45 55 L 30 55 Z" fill="#000000" stroke="#000000" stroke-width="2" stroke-linejoin="round"/>
          <path d="M 68 35 A 25 25 0 0 1 68 65" fill="none" stroke="#000000" stroke-width="4" stroke-linecap="round"/>
          <!-- Diagonal prohibition line -->
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'no_peatones':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <!-- Simple stickman -->
          <circle cx="50" cy="30" r="6" fill="#000000"/>
          <line x1="50" y1="36" x2="50" y2="55" stroke="#000000" stroke-width="5" stroke-linecap="round"/>
          <path d="M 50 40 L 40 60 M 50 40 L 60 60" stroke="#000000" stroke-width="5" stroke-linecap="round"/>
          <path d="M 50 55 L 40 80 M 50 55 L 60 80" stroke="#000000" stroke-width="5" stroke-linecap="round"/>
          <!-- Diagonal prohibition line -->
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'no_vuelta_u':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <path d="M 35 60 L 35 45 A 15 15 0 0 1 65 45 L 65 60" fill="none" stroke="#000000" stroke-width="8" stroke-linecap="round"/>
          <polygon points="65,65 55,50 75,50" fill="#000000"/>
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'no_bicicletas':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <!-- Simple bike -->
          <circle cx="35" cy="55" r="10" fill="none" stroke="#000000" stroke-width="4"/>
          <circle cx="65" cy="55" r="10" fill="none" stroke="#000000" stroke-width="4"/>
          <path d="M 35 55 L 45 40 L 60 40 L 65 55" fill="none" stroke="#000000" stroke-width="4" stroke-linejoin="round"/>
          <line x1="45" y1="40" x2="50" y2="55" stroke="#000000" stroke-width="4"/>
          <line x1="55" y1="30" x2="60" y2="40" stroke="#000000" stroke-width="4"/>
          <line x1="42" y1="40" x2="48" y2="40" stroke="#000000" stroke-width="4"/>
          <!-- Diagonal prohibition line -->
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'prohibido_adelantar':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#dc2626" stroke-width="12"/>
          <rect x="30" y="30" width="15" height="40" rx="4" fill="#000000" />
          <rect x="55" y="30" width="15" height="40" rx="4" fill="#dc2626" />
        </svg>
      `;
    case 'prohibido_estacionar':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#2563eb" stroke="#dc2626" stroke-width="12"/>
          <line x1="20" y1="20" x2="80" y2="80" stroke="#dc2626" stroke-width="10"/>
        </svg>
      `;
    case 'direccion_obligatoria':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="46" fill="#2563eb" stroke="#ffffff" stroke-width="2"/>
          <path d="M50 80 L50 30 M30 50 L50 20 L70 50" stroke="#ffffff" stroke-width="10" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      `;
    case 'rotonda':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="46" fill="#2563eb" stroke="#ffffff" stroke-width="2"/>
          <path d="M 50 20 A 30 30 0 0 1 76 65" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/>
          <path d="M 76 65 A 30 30 0 0 1 24 65" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/>
          <path d="M 24 65 A 30 30 0 0 1 50 20" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/>
          <polygon points="76,65 85,55 65,58" fill="white"/>
          <polygon points="24,65 15,55 35,58" fill="white"/>
          <polygon points="50,20 40,10 40,30" fill="white"/>
        </svg>
      `;
    case 'fin_limitaciones':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#000000" stroke-width="4"/>
          <line x1="20" y1="80" x2="80" y2="20" stroke="#4b5563" stroke-width="4"/>
          <line x1="25" y1="85" x2="85" y2="25" stroke="#4b5563" stroke-width="4"/>
          <line x1="15" y1="75" x2="75" y2="15" stroke="#4b5563" stroke-width="4"/>
        </svg>
      `;
    case 'curva_peligrosa':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <polygon points="50,10 95,90 5,90" fill="#ffffff" stroke="#dc2626" stroke-width="10" stroke-linejoin="round"/>
          <path d="M 50 80 L 50 50 M 50 50 C 50 30 70 30 70 30" stroke="#000000" stroke-width="8" stroke-linecap="round" fill="none"/>
          <polygon points="70,30 60,20 60,40" fill="#000000"/>
        </svg>
      `;
    case 'semaforo_adelante':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <polygon points="50,10 95,90 5,90" fill="#ffffff" stroke="#dc2626" stroke-width="10" stroke-linejoin="round"/>
          <rect x="40" y="35" width="20" height="45" rx="2" fill="#1f2937"/>
          <circle cx="50" cy="45" r="5" fill="#dc2626"/>
          <circle cx="50" cy="57" r="5" fill="#fbbf24"/>
          <circle cx="50" cy="69" r="5" fill="#16a34a"/>
        </svg>
      `;
    case 'peatones':
    case 'escolares':
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <polygon points="50,10 95,90 5,90" fill="#ffffff" stroke="#dc2626" stroke-width="10" stroke-linejoin="round"/>
          <path d="M 40 70 L 45 50 L 35 45 L 45 40 L 50 25 L 60 40 L 60 70" fill="none" stroke="#000000" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="50" cy="20" r="5" fill="#000000"/>
        </svg>
      `;
    default:
      // Si no es un ID SVG conocido, asume que es un Emoji y mételo en el SVG!
      return `
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-md">
          <text x="50" y="70" font-size="65" text-anchor="middle">${signName}</text>
        </svg>
      `;
  }
};

const svgContent = getSignalSVG(name);
---

<div class:list={["inline-flex items-center justify-center shrink-0", dimensions, className]} set:html={svgContent} />
